MISTRAL_API_KEY=...
MISTRAL_AGENT_ID=ag_...
MISTRAL_VOXTRAL_MODEL=voxtral-mini-transcribe-2507
MISTRAL_VOXTRAL_LANGUAGE=fr
MISTRAL_VOXTRAL_TEMPERATURE=0
BART_AI_MIN_AUDIO_BYTES=2048
BART_AI_VAD_DBFS_THRESHOLD=-45
BART_AI_VAD_MAX_SECONDS=3
BART_AI_VAD_SAMPLE_RATE=16000
BART_AI_VAD_AGGRESSIVENESS=2
BART_AI_VAD_FRAME_MS=30
BART_AI_VAD_MIN_SPEECH_MS=120
BART_AI_VAD_MIN_RATIO=0.02
# Debug/troubleshooting: set to true to bypass VAD gating.
BART_AI_DISABLE_VAD=false
INDEX_DIR=data/indexes/faiss

# Google OAuth (Gmail/Drive)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8002/oauth/google/callback
GOOGLE_OAUTH_CLIENT_TYPE=web
GOOGLE_TOKEN_PATH=.secrets/google_token.json

# Supabase Auth
# Required to enable account creation/login + Google sign-in/linking.
# Find these in Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Local filesystem tools (use with care)
# Semicolon-separated allowlist of directories the agent may access.
# Example:
# LOCAL_FS_ALLOWED_ROOTS=C:\\Users\\x\\ --> give access to everything under C:\Users\x\
LOCAL_FS_ALLOWED_ROOTS=

# Maximum bytes read from a file when using local_read_text
LOCAL_FS_MAX_READ_BYTES=200000

# Destructive operations (write/delete) are DISABLED by default.
# Set true only if you understand the risks.
LOCAL_FS_ENABLE_DESTRUCTIVE=false

# fs_* filesystem tools access control
# ACCESS_MODE:
# - safe: only allow paths within WORKSPACE_ROOT
# - full_disk: allow most paths, with a denylist for obvious secrets
ACCESS_MODE=safe

# Root used when ACCESS_MODE=safe
WORKSPACE_ROOT=./rag/data

# Additional denylist tokens for full_disk mode (semicolon-separated)
# Example: FS_DENYLIST=.git;node_modules
FS_DENYLIST=
